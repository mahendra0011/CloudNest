PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
MONGO_URI=mongodb://127.0.0.1:27017/cloudnest
JWT_SECRET=replace-with-a-long-random-secret

# Google OAuth web client credentials.
# Do not commit real values. Rotate any credentials that were pasted into chat.
# A Google API key alone cannot upload private Drive files; this app uses OAuth.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Owner Drive storage. All user uploads are saved to this Google Drive account.
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_OWNER_DRIVE_SCOPE=https://www.googleapis.com/auth/drive.file
OWNER_TOKEN_PORT=4000

# Optional: upload into a specific folder in the owner Google Drive.
GOOGLE_DRIVE_FOLDER_ID=
MAX_UPLOAD_MB=250
